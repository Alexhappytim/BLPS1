        {
          "name": "06. Get Course Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var payload = pm.response.json();",
                  "var data = payload.data || [];",
                  "var autoTask = data.find(function (t) { return t.reviewType === 'AUTO'; });",
                  "var mentorTask = data.find(function (t) { return t.reviewType === 'MENTOR'; });",
                  "pm.test('AUTO task exists', function () { pm.expect(autoTask).to.exist; });",
                  "pm.test('MENTOR task exists', function () { pm.expect(mentorTask).to.exist; });",
                  "if (autoTask) pm.environment.set('e2eAutoTaskId', autoTask.id);",
                  "if (mentorTask) pm.environment.set('e2eMentorTaskId', mentorTask.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{e2eUserEmail}}", "type": "string" },
                { "key": "password", "value": "{{e2eUserPassword}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?courseId={{e2eCourseId}}&page=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
