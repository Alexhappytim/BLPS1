    {
      "name": "E2E Main Business Process",
      "item": [
        {
          "name": "01. Register E2E User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var ts = Date.now().toString();",
                  "pm.environment.set('e2eRunTs', ts);",
                  "pm.environment.set('e2eUserEmail', 'e2e_user_' + ts + '@example.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "if (data.verificationToken) pm.environment.set('e2eVerificationToken', data.verificationToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2eUserEmail}}\",\n  \"password\": \"{{e2eUserPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "02. Confirm E2E User Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{e2eVerificationToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/confirm-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "confirm-email"]
            }
          }
        },
        {
          "name": "03. Get First Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var payload = pm.response.json();",
                  "var data = payload.data || [];",
                  "pm.test('At least one course exists', function () { pm.expect(data.length).to.be.above(0); });",
                  "if (data.length > 0) pm.environment.set('e2eCourseId', data[0].id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{e2eUserEmail}}", "type": "string" },
                { "key": "password", "value": "{{e2eUserPassword}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses?page=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [{ "key": "page", "value": "0" }]
            }
          }
        },
