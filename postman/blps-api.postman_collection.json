  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"{{newUserPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.verificationToken) pm.environment.set('verificationToken', data.verificationToken);",
                  "if (data.email) pm.environment.set('basicUsername', data.email);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/confirm-email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
