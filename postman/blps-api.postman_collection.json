    {
      "name": "5. Submit Mentor Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var data = pm.response.json();",
              "if (data && data.submissionId) {",
              "  pm.environment.set('mentorSubmissionId', data.submissionId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{login}}\",\n  \"taskId\": {{mentorTaskId}},\n  \"difficulty\": \"HARD\",\n  \"reviewType\": \"MENTOR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks/submit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tasks",
            "submit"
          ]
        }
      },
      "response": []
    },
